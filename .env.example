# Environment Configuration
# Docker Compose file to use (docker-compose.yml for dev, docker-compose.prod.yml for production)
COMPOSE_FILE=docker-compose.yml

# Ollama Configuration

# Host where Ollama listens (0.0.0.0 for external access)
OLLAMA_HOST=0.0.0.0

# Maximum number of models loaded simultaneously
OLLAMA_MAX_LOADED_MODELS=2

# Number of parallel threads for processing
OLLAMA_NUM_PARALLEL=4

# Maximum queue size for requests
OLLAMA_MAX_QUEUE=512

# Port for Ollama API
OLLAMA_PORT=11434

# Port for web interface
WEBUI_PORT=3000

# Secret key for web interface (change in production)
WEBUI_SECRET_KEY=your-secret-key-change-this

# Memory limits - CUSTOMIZE FOR YOUR HARDWARE
# For M4 Mac (12GB Docker limit):
MEMORY_LIMIT=26G
MEMORY_RESERVATION=8G

# Logging configuration
OLLAMA_DEBUG=false

# Path where models are stored (inside container)
OLLAMA_MODELS_PATH=/root/.ollama

# Network configuration
OLLAMA_NETWORK=bridge

# LiteLLM Configuration (AI API Gateway)
# Master API key para autenticación de la API
LITELLM_MASTER_KEY=sk-1234567890abcdef

# Password para UI de administración
LITELLM_UI_PASSWORD=changeme123